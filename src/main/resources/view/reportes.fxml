<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="480.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ControladorReportes">
    <children>
        <Label layoutX="20.0" layoutY="20.0" text="Reporte de Inventario Actual">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>
        <TableView fx:id="tvReportes" layoutX="20.0" layoutY="60.0" prefHeight="400.0" prefWidth="660.0">
            <columns>
                <TableColumn fx:id="colNombre" prefWidth="331.0" text="Producto" />
                <TableColumn fx:id="colStock" prefWidth="328.0" text="Unidades Disponibles (Stock)" />
            </columns>
        </TableView>
    </children>
</AnchorPane>
