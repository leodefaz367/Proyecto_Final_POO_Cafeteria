<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="525.0" prefWidth="800.0" stylesheets="@../css/estilos.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ControladorVentas">
   <children>
      <Label layoutX="20.0" layoutY="15.0" styleClass="titulo" text="Punto de Venta" />
      <TitledPane animated="false" collapsible="false" layoutX="20.0" layoutY="50.0" prefHeight="100.0" prefWidth="760.0" text="Datos del Cliente">
         <content>
            <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="46.0" prefWidth="728.0">
               <children>
                  <Label layoutX="14.0" layoutY="10.0" text="Cédula/RUC:" />
                  <TextField fx:id="txtCedula" layoutX="101.0" prefWidth="150.0" promptText="9999999999" />
                  <Label layoutX="273.0" layoutY="10.0" text="Nombre:" />
                  <TextField fx:id="txtNombreCliente" layoutX="328.0" prefWidth="250.0" promptText="Consumidor Final" />
               </children>
            </AnchorPane>
         </content>
      </TitledPane>
      <Label layoutX="20.0" layoutY="166.0" styleClass="titulo" text="Producto:" />
      <ComboBox fx:id="cmbProducto" layoutX="142.0" layoutY="159.0" promptText="Seleccione Producto" />
      <Label layoutX="357.0" layoutY="165.0" styleClass="titulo" text="Cantidad:" />
      <TextField fx:id="txtCantidad" layoutX="475.0" layoutY="162.0" prefWidth="60.0" />
      <Button layoutX="584.0" layoutY="163.0" mnemonicParsing="false" onAction="#agregarAlCarrito" text="Agregar al Carrito" />
      <TableView fx:id="tvCarrito" layoutX="20.0" layoutY="208.0" prefHeight="205.0" prefWidth="760.0">
         <columns>
            <TableColumn fx:id="colProducto" prefWidth="208.0" text="Producto" />
            <TableColumn fx:id="colCantidad" prefWidth="196.0" text="Cantidad" />
            <TableColumn fx:id="colPrecio" prefWidth="177.0" text="Precio Unitario" />
            <TableColumn fx:id="colSubtotal" prefWidth="177.0" text="Subtotal" />
         </columns>
      </TableView>
      <Button layoutX="20.0" layoutY="422.0" mnemonicParsing="false" onAction="#eliminarDelCarrito" styleClass="button-danger" text="Eliminar Producto" />
      <Button layoutX="188.0" layoutY="422.0" mnemonicParsing="false" onAction="#editarCantidad" text="Modificar Cantidad" />
      <Label layoutX="480.0" layoutY="444.0" styleClass="titulo" text="TOTAL A PAGAR: $" />
      <Label fx:id="lblTotal" layoutX="714.0" layoutY="444.0" styleClass="titulo" text="0.00" />
      <Button layoutX="20.0" layoutY="467.0" mnemonicParsing="false" onAction="#procesarVenta" prefHeight="45.0" prefWidth="220.0" styleClass="button-success" text="Confirmar Venta" />
   </children>
</AnchorPane>
